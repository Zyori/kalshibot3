# Copy to .env and fill in. NEVER commit .env.
# All env vars are loaded by backend/src/config.py (Pydantic Settings).

# === Runtime environment ===
# Controls which Kalshi API the app talks to.
# Allowed: "demo" (no real money) or "production" (real money).
# Switching requires a process restart. There is no UI toggle by design.
ENVIRONMENT=demo

# === Kalshi API ===
# Path to the RSA private key Kalshi issued for your account.
# File permissions MUST be 0o600 or stricter — the app refuses to start otherwise.
KALSHI_KEY_PATH=/var/www/lutz-bot/secrets/kalshi-demo.pem
# The key ID Kalshi shows alongside the private key.
KALSHI_KEY_ID=

# === Sports data ===
# API-Football (https://www.api-football.com/). Required for soccer live data.
# Pro tier ($19/mo) is sufficient if Odds API covers odds.
API_FOOTBALL_KEY=

# The Odds API (https://the-odds-api.com/). Used for cross-book odds comparison.
ODDS_API_KEY=

# === LLM ===
# Provider undecided — left blank until Phase 4. The llm/ adapter layer abstracts the choice.
LLM_PROVIDER=
LLM_API_KEY=

# === Database ===
# SQLite path. Lives outside the source tree so it's not bundled in a dist.
DATABASE_PATH=/var/www/lutz-bot/data/kalshibot.db

# === Bankroll ===
# Used by Kelly sizing. Update as bankroll grows.
BANKROLL_USD=500
